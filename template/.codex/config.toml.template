# Optional project-local Codex config template.
#
# Copy to `.codex/config.toml` only when this project needs local Codex
# overrides. Keep `.codex/` local-only by default.
#
# Codex can run the shared Agentic SDLC contract independently. Claude Code is
# a separate runtime/team layer available through the handoff contract when
# that extra architecture is useful.
#
# Do not store secrets or provider tokens in this file.

multi_agent = true
