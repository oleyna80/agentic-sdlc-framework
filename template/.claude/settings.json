{
  "enabledMcpjsonServers": [
    "codex"
  ],
  "permissions": {
    "allow": [
      "mcp__codex__codex"
    ]
  },
  "autoMode": {
    "allow": [
      "$defaults"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/hard-stop.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/critic-gate.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/typecheck.sh",
            "timeout": 30000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/verification-gate.sh",
            "timeout": 5000
          }
        ]
      }
    ]
  },
  "agents": {
    "solution-architect": {
      "description": "Pre-implementation research (read-only)",
      "color": "green"
    },
    "critic": {
      "description": "Independent review of Control Tower decisions, Stage 0\u21921 (read-only)",
      "color": "yellow"
    },
    "gpt-critic": {
      "description": "External adversarial review of Control Tower decisions via Codex MCP (read-only)",
      "color": "orange"
    },
    "reviewer": {
      "description": "Read-only multi-dimension review across code, docs, architecture, drift, and security triage",
      "color": "yellow"
    },
    "scoped-coder": {
      "description": "Approved-scope implementation only; one write-capable coder per write-set",
      "color": "blue"
    },
    "verifier": {
      "description": "Post-implementation verification gate (read-only)",
      "color": "red"
    },
    "gpt-verifier": {
      "description": "External adversarial verification via Codex MCP (read-only)",
      "color": "purple"
    },
    "codex-reviewer": {
      "description": "Optional extra-deep Codex MCP review beyond the default GPT verifier",
      "color": "blue"
    }
  }
}
