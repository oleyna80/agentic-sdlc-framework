{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/hard-stop.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/typecheck.sh",
            "timeout": 30000
          }
        ]
      }
    ]
  },
  "agents": {
    "solution-architect": {
      "description": "Pre-implementation research (read-only)",
      "color": "green"
    },
    "verifier": {
      "description": "Post-implementation verification gate (read-only)",
      "color": "red"
    }
  }
}
