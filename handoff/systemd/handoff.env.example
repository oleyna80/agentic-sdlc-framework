# Optional environment for the Agentic SDLC handoff watcher user service.
# Installed by handoff/runner/install-systemd-user-service.sh to:
#   ~/.config/agentic-sdlc-framework/handoff.env
#
# Keep this file mode 600 if you add tokens.

# systemd user services often have a smaller PATH than interactive shells.
# Include the directories where claude, git, flock, timeout, and bash are found.
PATH=/usr/local/bin:/usr/bin:/bin

# Watcher behavior.
HANDOFF_WATCH_INTERVAL=5
HANDOFF_WATCH_STABLE_SECONDS=1

# Runner behavior.
HANDOFF_TIMEOUT_SECONDS=1800
HANDOFF_CLAUDE_MAX_BUDGET_USD=0.50
HANDOFF_SCOPE_AUDIT=1

# Claude Code / model routing. Uncomment and fill only what this host needs.
# ANTHROPIC_BASE_URL=
# ANTHROPIC_API_KEY=
# ANTHROPIC_AUTH_TOKEN=
# ANTHROPIC_MODEL=
# ANTHROPIC_DEFAULT_SONNET_MODEL=
# ANTHROPIC_DEFAULT_OPUS_MODEL=
# ANTHROPIC_DEFAULT_HAIKU_MODEL=
# CLAUDE_CODE_SUBAGENT_MODEL=
# DEEPSEEK_API_KEY=
